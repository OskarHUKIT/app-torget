    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "next": "^14.2.0",
    "next-pwa": "^5.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-leaflet": "^4.2.1",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.1",
